# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_ORG_ID=org-your-org-id-here
OPENAI_PROJECT_ID=proj_your-project-id-here
DEFAULT_MODEL=gpt-4o

# Security
SECRET_KEY=generate-a-random-64-character-hex-string-here

# Admin Configuration
ADMIN_EMAIL=your-admin-email@example.com

# Email Configuration (for user invitations)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_FROM=your-email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Application Configuration
TEMPERATURE=0.2
WEBSOCKET_PING_INTERVAL=30
STREAMING_DELAY=0.01

# Database
DATABASE_URL=sqlite:///./mysite.db

# Optional: ASL System Instructions
ASL_SYSTEM_INSTRUCTIONS=You are an expert on Advanced Squad Leader (ASL) rules.

# Production Notes:
# 1. Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
# 2. For Gmail, use App Passwords: https://myaccount.google.com/apppasswords
# 3. Copy this file to .env and fill in real values
# 4. Never commit .env with real values to git!

